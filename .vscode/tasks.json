{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Serve preview",
			"type": "shell",
			"command": "npx -y http-server -p 5173 -c-1 .",
			"isBackground": true,
			"problemMatcher": {
				"owner": "http-server",
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Available on|Hit CTRL-C"
				}
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated"
			}
		}
	]
}
